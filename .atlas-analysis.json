  "keyFeatures": [
    "TypeScript-first React Native setup with strict type checking",
    "React Navigation with typed routes and multi-stack architecture",
    "Context-based state management (Auth, Account, Task)",
    "Formik + Yup form handling with validation",
    "Datadog monitoring and error tracking integration",
    "i18next internationalization support",
    "CI/CD pipelines with SonarQube quality gates",
    "Fastlane automation for iOS and Android deployments",
    "Native Base UI component library integration",
    "Docker support for containerized development"
  ],
  "publicApiSurface": [
    "AuthContextProvider - Authentication state management",
    "AccountContextProvider - User account state management",
    "TaskContextProvider - Task state management",
    "api-service - HTTP client with Axios",
    "auth.service - Authentication API calls",
    "account.service - Account management API calls",
    "task.service - Task management API calls",
    "Logger - Logging utility with Datadog integration",
    "ApplicationNavigator - Main navigation container",
    "ErrorFallback - Error boundary component",
    "UI Components - Alert, Avatar, Badge, Button, Card, Checkbox, Form Controls, Inputs, Modal, Radio, Spinner, Tag, Typography"
  ]
}
